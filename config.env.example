# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# LLM Settings
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# Application Settings
ENVIRONMENT=development  # development, production
LOG_LEVEL=info
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000

# File Storage
UPLOAD_DIR=uploads
DOWNLOAD_DIR=downloads
MAX_FILE_SIZE=10485760

# Security
SECRET_KEY=your_secret_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (for future use)
DATABASE_URL=sqlite:///./grakibana.db
REDIS_URL=redis://localhost:6379

# Enable LLM-powered conversion (set to true to enable, false to disable)
ENABLE_LLM_CONVERSION=false

# EDOT Browser / OTLP proxy
# Your Elastic Observability APM endpoint (no trailing slash)
OTLP_ENDPOINT=https://<project-alias>.apm.<region>.aws.elastic.cloud
# API key with APM ingest privileges — keep this server-side only
OTLP_API_KEY=your_elastic_api_key_here 